    {
      "question": "负向声量最多的前 10 个具体问题是什么?",
      "sql": "SELECT fifth_category, COUNT(*) AS cnt\nFROM fact_voc\nWHERE emotion = '负向声量'\nGROUP BY fifth_category\nORDER BY cnt DESC\nLIMIT 10;"
