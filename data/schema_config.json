    {
      "question": "最近几个月的声量趋势如何?",
      "sql": "SELECT SUBSTR(pt_d,1,6) AS month,\n       COUNT(*) AS total,\n       SUM(CASE WHEN emotion = '负向声量' THEN 1 ELSE 0 END) AS negative\nFROM fact_voc\nGROUP BY month\nORDER BY month;"
    },
    {
      "question": "各个渠道的负向占比是多少?",
      "sql": "SELECT data_channel,\n       COUNT(*) AS total,\n       SUM(CASE WHEN emotion = '负向声量' THEN 1 ELSE 0 END) AS negative,\n       ROUND(100.0 * SUM(CASE WHEN emotion = '负向声量' THEN 1 ELSE 0 END) / COUNT(*), 2) AS neg_ratio\nFROM fact_voc\nGROUP BY data_channel\nORDER BY total DESC;"
    },
    {
      "question": "本月和上月相比,哪类问题的负向投诉增长最多?",
      "sql": "WITH cur AS (\n  SELECT fifth_category, COUNT(*) AS cur_cnt\n  FROM fact_voc\n  WHERE SUBSTR(pt_d,1,6) = '202604' AND emotion = '负向声量'\n  GROUP BY fifth_category\n), pre AS (\n  SELECT fifth_category, COUNT(*) AS pre_cnt\n  FROM fact_voc\n  WHERE SUBSTR(pt_d,1,6) = '202603' AND emotion = '负向声量'\n  GROUP BY fifth_category\n)\nSELECT c.fifth_category,\n       c.cur_cnt,\n       COALESCE(p.pre_cnt, 0) AS pre_cnt,\n       (c.cur_cnt - COALESCE(p.pre_cnt, 0)) AS delta\nFROM cur c LEFT JOIN pre p USING(fifth_category)\nORDER BY delta DESC\nLIMIT 10;"
    },
    {
      "question": "社媒渠道本月的负向问题 TOP 有哪些?",
      "sql": "SELECT fifth_category, COUNT(*) AS cnt\nFROM fact_voc\nWHERE SUBSTR(pt_d,1,6) = '202604'\n  AND data_channel = '社媒'\n  AND emotion = '负向声量'\nGROUP BY fifth_category\nORDER BY cnt DESC\nLIMIT 10;"
    },
    {
      "question": "『续航优秀』这个问题最近几个月的变化趋势?",
      "sql": "SELECT SUBSTR(pt_d,1,6) AS month, COUNT(*) AS cnt\nFROM fact_voc\nWHERE fifth_category = '续航优秀'\n  AND emotion = '负向声量'\nGROUP BY month\nORDER BY month;"
    },
    {
      "question": "整体情感分布是怎样的?",
      "sql": "SELECT emotion,\n       COUNT(*) AS cnt,\n       ROUND(100.0 * COUNT(*) / SUM(COUNT(*)) OVER (), 2) AS ratio\nFROM fact_voc\nGROUP BY emotion\nORDER BY cnt DESC;"
